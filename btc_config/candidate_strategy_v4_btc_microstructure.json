{
  "name": "leiting_v4_btc_microstructure_demo",
  "engine_mode": "v4_microstructure",
  "symbols": [
    "BTCUSDT"
  ],
  "interval": "5m",
  "allow_long": true,
  "allow_short": true,
  "maker_first": true,
  "maker_entry_timeout_sec": 10.0,
  "maker_price_ticks": 0,
  "threshold": 0.52,
  "ema_fast_bars": 9,
  "ema_slow_bars": 21,
  "breakout_lookback_bars": 20,
  "min_ema_gap_pct": 0.12,
  "require_breakout_confirmation": true,
  "require_flow_confirmation": true,
  "min_taker_buy_ratio_long": 1.03,
  "max_taker_buy_ratio_short": 0.97,
  "min_aggressive_flow_delta_long": 50.0,
  "max_aggressive_flow_delta_short": -50.0,
  "min_depth_imbalance_long": 0.08,
  "max_depth_imbalance_short": -0.08,
  "min_microprice_bias_bps_long": 0.12,
  "max_microprice_bias_bps_short": -0.12,
  "min_ofi_window_sum_long": 20.0,
  "max_ofi_window_sum_short": -20.0,
  "min_execution_quality_score": 8.4,
  "max_spread_bps": 0.7,
  "max_estimated_slippage_bps": 0.8,
  "take_profit_net_roi_pct": 80.0,
  "hard_stop_net_roi_pct": 28.0,
  "estimated_fee_bps_per_side": 5.0,
  "enable_breakeven": false,
  "enable_trailing": false,
  "notes": [
    "BTC 单标的",
    "100x demo，maker-first 被动限价进场",
    "5m breakout + OFI/microprice/depth/taker flow 双确认",
    "只在执行质量干净时出手",
    "先跑 demo 收集 forward 样本，再决定是否进一步放宽"
  ]
}
