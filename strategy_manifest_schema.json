{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "allowed_liquidity_buckets": { "items": { "type": "string" }, "type": "array" },
    "allowed_regimes": { "items": { "type": "string" }, "type": "array" },
    "blocked_regimes": { "items": { "type": "string" }, "type": "array" },
    "blocked_symbols": { "items": { "type": "string" }, "type": "array" },
    "created_at": { "type": "string" },
    "edge_source": { "minLength": 1, "type": "string" },
    "entry_conditions": { "items": { "type": "string" }, "type": "array" },
    "evidence_level": { "maximum": 5, "minimum": 0, "type": "integer" },
    "exit_logic": { "items": { "type": "string" }, "type": "array" },
    "expected_gross_move_bps": { "type": ["number", "null"] },
    "expected_holding_horizon_sec": { "items": { "type": "number" }, "type": "array" },
    "family": { "minLength": 1, "type": "string" },
    "invalidation_conditions": { "items": { "type": "string" }, "type": "array" },
    "market_hypothesis": { "minLength": 1, "type": "string" },
    "max_expected_total_cost_bps": { "type": ["number", "null"] },
    "min_cost_to_edge_ratio": { "type": ["number", "null"] },
    "min_expected_net_edge_bps": { "type": ["number", "null"] },
    "old_strategy_similarity": { "type": "object" },
    "replay_evidence": { "type": "object" },
    "shadow_evidence": { "type": "object" },
    "status": {
      "enum": ["disabled", "shadow_only", "candidate_shadow", "limited_testnet", "promoted_testnet", "mainnet_blocked"],
      "type": "string"
    },
    "strategy_id": { "minLength": 1, "type": "string" },
    "testnet_evidence": { "type": "object" },
    "trigger_event": { "minLength": 1, "type": "string" },
    "updated_at": { "type": "string" },
    "version": { "minLength": 1, "type": "string" },
    "who_loses_money": { "minLength": 1, "type": "string" }
  },
  "required": [
    "strategy_id",
    "version",
    "family",
    "status",
    "market_hypothesis",
    "edge_source",
    "who_loses_money",
    "trigger_event",
    "entry_conditions",
    "invalidation_conditions",
    "exit_logic",
    "allowed_regimes",
    "blocked_regimes",
    "allowed_liquidity_buckets",
    "blocked_symbols",
    "expected_holding_horizon_sec",
    "expected_gross_move_bps",
    "max_expected_total_cost_bps",
    "min_expected_net_edge_bps",
    "min_cost_to_edge_ratio",
    "evidence_level",
    "shadow_evidence",
    "replay_evidence",
    "testnet_evidence",
    "old_strategy_similarity",
    "created_at",
    "updated_at"
  ],
  "title": "Phoenix Strategy Manifest",
  "type": "object"
}
