# Hermes model provider
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Telegram gateway
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_PROXY=http://127.0.0.1:7890
HERMES_TELEGRAM_DISABLE_FALLBACK_IPS=true
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
ALL_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost

# Optional: keep Telegram mention behavior simple in private chats
TELEGRAM_REQUIRE_MENTION=false

# Optional: extra web/search tools for Hermes itself
EXA_API_KEY=
PARALLEL_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# Keep Phoenix trading secrets in /etc/phoenix/phoenix.env
# instead of duplicating them here.
