# BTC 执行节点主账户 API 模板
# 不要把真实 key 发到聊天里，只写到服务器环境文件

# 账户模式：
# - classic_um = 经典 USDⓈ-M Futures (fapi)
# - portfolio_margin = 统一账户 PM (papi)
BTC_ACCOUNT_API=classic_um

# 交易标的，第一阶段只做 BTCUSDT
BTC_SYMBOL=BTCUSDT

# 主账户 API Key
BTC_BINANCE_API_KEY=REPLACE_ME
BTC_BINANCE_API_SECRET=REPLACE_ME

# 环境
BTC_BINANCE_ENV=prod

# 如果需要代理，显式写出
BTC_ALL_PROXY=http://127.0.0.1:7890

# 风控
BTC_EXECUTION_MODE=MANUAL_CONFIRM
BTC_REVIEW_JOURNAL_MODE=prod
BTC_MAX_OPEN_POSITIONS=1
BTC_DEFAULT_LEVERAGE=10
BTC_ALLOW_AUTO_SHORT=false
BTC_RISK_BUDGET_PCT=1.0

# WebSocket / 数据
BTC_KLINE_INTERVAL=5m
BTC_BACKFILL_DAYS=90
BTC_USER_STREAM_ENABLED=true
BTC_MARKET_STREAM_ENABLED=true

# review / 对接
BTC_REVIEW_BATCH_TRADES=10
BTC_HERMES_REVIEW_TARGET=/root/.hermes/memories/btc_reviews
BTC_HERMES_REVIEW_SSH_KEY_PATH=REPLACE_ME
BTC_HERMES_REVIEW_REMOTE_CMD="python3 /opt/phoenix/deploy/hermes/leiting_formal_review_digest.py --hermes-home /root/.hermes --notify-telegram"
BTC_HERMES_RESEARCH_TARGET=/root/.hermes/memories/btc_research
BTC_HERMES_RESEARCH_REMOTE_CMD=
BTC_DEMO_START_EQUITY_USDT=1000
BTC_DEMO_POSITION_FRACTION=0.20
BTC_DEMO_LEVERAGE=1
BTC_DEMO_CANDIDATE_CONFIG=btc_config/candidate_strategy_v1_trend_only.json

# 说明
# 1. 主账户交易建议只在新服务器上使用
# 2. 不要开启提现权限
# 3. 白名单只放新服务器出口 IP
