{
  "profile": "stage2_micro_order",
  "mode": "testnet",
  "provider": "file",
  "decision_policy": "calibration",
  "decision_timeout_sec": 60,
  "decision_poll_interval_sec": 0.5,
  "interval_sec": 10,
  "duration_min": 60,
  "testnet_only": true,
  "mainnet_live": false,
  "mainnet_hard_block": true,
  "auto_promotion": false,
  "max_open_positions": 1,
  "leverage": 2,
  "quote_allocation_usdt": 5.0,
  "max_quote_allocation_usdt": 10.0,
  "micro_notional": true,
  "stage2_micro_order": true,
  "lifecycle_monitor_enabled": true,
  "lifecycle_poll_sec": 5,
  "lifecycle_post_close_wait_sec": 60,
  "stop_loss_required": true,
  "take_profit_required": true,
  "max_holding_time_required": true,
  "invalidation_required": true,
  "invalidation_condition_required": true,
  "require_known_market_regime": true,
  "no_averaging_down": true,
  "no_martingale": true,
  "isolated_margin_only": true,
  "loss_streak_lock": true,
  "daily_loss_limit": true,
  "cooldown_after_loss": true,
  "max_daily_loss_pct": 1.0,
  "cooldown_after_loss_sec": 900,
  "output_dir": "/opt/phoenix-testnet/hermes_logs/stage2_micro_testnet",
  "dashboard_snapshot_url": "http://127.0.0.1:18765/api/phoenix-dashboard-snapshot",
  "dashboard_token_file": "/opt/phoenix-testnet/.phoenix_dashboard_readonly_token",
  "dashboard_timeout_sec": 30,
  "hermes_inbox": "/opt/phoenix-testnet/hermes_inbox",
  "hermes_outbox": "/opt/phoenix-testnet/hermes_outbox",
  "hermes_archive": "/opt/phoenix-testnet/hermes_archive",
  "hermes_logs": "/opt/phoenix-testnet/hermes_logs"
}
